---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Absolute or root-relative path. Astro resolves canonical from Astro.url. */
  canonicalPath?: string;
  /** Override the og:image — defaults to /og.png (the umbrella card). */
  ogImage?: string;
  /** Marks the active nav link. */
  active?: 'home' | 'sheets' | 'editor' | 'desktop' | 'docs' | 'changelog' | 'about';
  /** Per-page JSON-LD payload (will be JSON.stringify'd). */
  jsonLd?: object;
  /** Theme color hint sent in the meta tag. */
  themeColor?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogImage = '/og.png',
  active = 'home',
  jsonLd,
  themeColor = '#fafaf7',
} = Astro.props as Props;

const SITE_URL = 'https://schnsrw.live';
const canonical = canonicalPath
  ? new URL(canonicalPath, SITE_URL).toString()
  : new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageAbs = new URL(ogImage, SITE_URL).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Sachin Sarwa" />
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content="light" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Casual Office" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="twitter:image:alt" content={title} />

    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600;8..60,700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <div class="aurora" aria-hidden="true"></div>
    <Nav active={active} />
    <main><slot /></main>
    <Footer />
  </body>
</html>
