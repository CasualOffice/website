---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const all = await getCollection('docs');
const grouped: Record<string, typeof all> = { sheets: [], editor: [], shared: [] };
for (const e of all) grouped[e.data.product].push(e);
for (const k of Object.keys(grouped)) grouped[k].sort((a, b) => a.data.order - b.data.order);

const PRODUCT_LABELS: Record<string, string> = {
  sheets: 'Casual Sheets',
  editor: 'Casual Docs',
  shared: 'Shared concepts',
};
const PRODUCT_ACCENTS: Record<string, string> = {
  sheets: 'var(--sheets)',
  editor: 'var(--editor)',
  shared: 'var(--accent)',
};
const PRODUCT_BLURBS: Record<string, string> = {
  sheets: 'Plan, architecture, research notes, co-editing internals, the large-file pipeline, fork-side perf, lossiness audits, and the Docker bundle.',
  editor: 'Architecture, co-editing protocol, round-trip fidelity, and deployment.',
  shared: 'Concepts that span both editors.',
};

const title = 'Documentation · Casual Office';
const description =
  'Architecture, research notes, plans, and operational guides for Casual Sheets and Casual Docs. Pulled and curated from each repo.';
---
<Base {title} {description} active="docs">
  <section class="hero">
    <div class="container hero__inner reveal">
      <span class="eyebrow">Documentation</span>
      <h1 class="display">A thin curated view over the upstream sources.</h1>
      <p class="lede">
        Every entry here is synced from the canonical markdown file in the
        matching repo. The "Edit on GitHub" link on each page points back to
        the source of truth — re-run <code>npm run sync-docs</code> to pull
        the latest into the site.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="docs-hub">
        {(['sheets', 'editor', 'shared'] as const).map((p) => (
          grouped[p].length === 0 ? null : (
            <article class="docs-hub__group" style={`--group-accent: ${PRODUCT_ACCENTS[p]};`}>
              <header class="docs-hub__header">
                <div class="docs-hub__title">
                  <span class="docs-hub__dot" aria-hidden="true"></span>
                  {PRODUCT_LABELS[p]}
                </div>
                <p class="docs-hub__blurb">{PRODUCT_BLURBS[p]}</p>
              </header>
              <ul class="docs-hub__list">
                {grouped[p].map((e) => (
                  <li>
                    <a href={`/docs/${e.slug}/`} class="docs-hub__link">
                      <span class="docs-hub__entry-title">{e.data.title}</span>
                      {e.data.summary && <span class="docs-hub__entry-summary">{e.data.summary}</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </article>
          )
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .docs-hub {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (max-width: 820px) {
    .docs-hub { grid-template-columns: 1fr; }
  }
  .docs-hub__group {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 26px 26px 18px;
    position: relative;
    overflow: hidden;
  }
  .docs-hub__group::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--group-accent);
    opacity: 0.7;
  }
  .docs-hub__header { margin-bottom: 14px; }
  .docs-hub__title {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .docs-hub__dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--group-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--group-accent) 12%, transparent);
  }
  .docs-hub__blurb {
    margin: 8px 0 0;
    font-size: 14px;
    color: var(--text-soft);
    line-height: 1.55;
  }
  .docs-hub__list {
    list-style: none;
    margin: 0;
    padding: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-top: 1px dashed var(--border);
  }
  .docs-hub__link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 14px;
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: background 120ms ease-out, transform 120ms ease-out;
  }
  .docs-hub__link:hover {
    background: var(--surface-2);
    text-decoration: none;
    color: var(--text);
  }
  .docs-hub__entry-title { font-weight: 600; font-size: 15px; }
  .docs-hub__entry-summary { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
</style>
