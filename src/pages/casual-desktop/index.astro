---
import Base from '../../layouts/Base.astro';

const title = 'Casual Desktop — offline Sheets + Editor in a Tauri binary · Casual Office';
const description =
  'Casual Desktop — a native binary for macOS, Linux, and Windows that reuses the Casual Docs and Casual Sheets web cores verbatim. Single-user, offline, signed in-app auto-update. Download v0.0.3.';

// Release downloads. Versioned URLs so a button always points at a known-good
// asset; bump `version` (and the asset names if the bundle naming changes) on
// each release. GitHub rewrites the space in "Casual Office" to a dot.
const version = '0.0.3';
const base = `https://github.com/CasualOffice/desktop/releases/download/v${version}`;
const downloads = {
  mac: `${base}/Casual.Office_${version}_universal.dmg`,
  linuxAppImage: `${base}/Casual.Office_${version}_amd64.AppImage`,
  linuxDeb: `${base}/Casual.Office_${version}_amd64.deb`,
  winExe: `${base}/Casual.Office_${version}_x64-setup.exe`,
  winMsi: `${base}/Casual.Office_${version}_x64_en-US.msi`,
};
const releasesUrl = 'https://github.com/CasualOffice/desktop/releases/latest';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': 'https://casualoffice.org/casual-desktop/#app',
  name: 'Casual Desktop',
  applicationCategory: 'DesktopEnhancementApplication',
  operatingSystem: 'macOS, Linux, Windows',
  url: 'https://casualoffice.org/casual-desktop/',
  downloadUrl: releasesUrl,
  softwareVersion: version,
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  description:
    'Tauri binaries that reuse the Casual Docs and Casual Sheets web cores verbatim — single-user, offline, with signed in-app auto-update. Available for macOS, Linux, and Windows.',
  image: 'https://casualoffice.org/og.png',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: {
    '@type': 'Person',
    '@id': 'https://casualoffice.org/#person',
    name: 'Sachin Sarwa',
    url: 'https://casualoffice.org/',
  },
  isAccessibleForFree: true,
  softwareRequirements: 'macOS 12+, Linux (modern), Windows 10+',
};
---
<Base {title} {description} active="desktop" jsonLd={jsonLd} ogImage="/og-desktop.png">
  <section
    class="hero subpage"
    style="--product-accent: var(--desktop); --product-accent-soft: var(--desktop-soft);"
  >
    <div class="container hero__inner reveal">
      <div class="subpage__topline">
        <span class="dot" aria-hidden="true"></span>
        Casual Desktop · v{version}
      </div>
      <h1 class="display">The same editors, <em>off the network.</em></h1>
      <p class="lede">
        A native binary that reuses the Casual Docs and Casual Sheets web cores
        verbatim. Single-user, offline. Tauri shell, Rust glue. macOS, Linux,
        Windows. Same shipped UX as the web, no SaaS in the loop.
      </p>
      <div class="row">
        <a
          id="primary-download"
          class="btn btn--primary"
          href={releasesUrl}
          rel="noopener"
          data-mac={downloads.mac}
          data-win={downloads.winExe}
          data-linux={downloads.linuxDeb}
        >Download Casual Office</a>
        <a class="btn btn--ghost" href={releasesUrl} rel="noopener" target="_blank">All downloads</a>
      </div>
      <p class="lede" style="font-size: 0.92rem; opacity: 0.7; margin-top: 12px;">
        <span id="download-detail">
          macOS <a href={downloads.mac} rel="noopener">.dmg</a> ·
          Linux <a href={downloads.linuxDeb} rel="noopener">.deb</a> /
          <a href={downloads.linuxAppImage} rel="noopener">.AppImage</a> ·
          Windows <a href={downloads.winExe} rel="noopener">.exe</a> /
          <a href={downloads.winMsi} rel="noopener">.msi</a> ·
          <a href={releasesUrl} rel="noopener" target="_blank">checksums</a>.
        </span>
        Apache-2.0. Installers are unsigned in the OS sense — on macOS,
        right-click → Open on first launch.
      </p>
      <script is:inline>
        // Point the primary button at the visitor's OS. No-JS / unknown OS
        // falls back to the releases page (the button's default href).
        (function () {
          var el = document.getElementById('primary-download');
          if (!el) return;
          var s = (navigator.userAgent || '') + ' ' + (navigator.platform || '');
          var os = /Win/i.test(s)
            ? 'win'
            : /Mac|iPhone|iPad|iPod/i.test(s)
              ? 'mac'
              : /Linux|X11|CrOS/i.test(s)
                ? 'linux'
                : '';
          var label = {
            mac: 'Download for macOS',
            win: 'Download for Windows',
            linux: 'Download for Linux',
          };
          var href = { mac: el.dataset.mac, win: el.dataset.win, linux: el.dataset.linux };
          if (os && href[os]) {
            el.textContent = label[os];
            el.setAttribute('href', href[os]);
          }
        })();
      </script>
    </div>
  </section>

  <section class="section" style="--product-accent: var(--desktop); --product-accent-soft: var(--desktop-soft);">
    <div class="container">
      <div class="fact-row">
        <div><div class="fact__label">Version</div><div class="fact__value">v{version}</div></div>
        <div><div class="fact__label">Targets</div><div class="fact__value">3 OSes</div></div>
        <div><div class="fact__label">Updates</div><div class="fact__value">signed, in-app</div></div>
        <div><div class="fact__label">Shell</div><div class="fact__value">Tauri</div></div>
      </div>
    </div>
  </section>

  <section class="section" style="--product-accent: var(--desktop); --product-accent-soft: var(--desktop-soft);">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">The shape</span>
          <h2 class="title">Reuse the web build. Replace the chrome.</h2>
        </div>
      </div>
      <div class="feature-grid">
        <article class="feature">
          <span class="feature__icon">↻</span>
          <h3 class="feature__title">Same web cores, verbatim</h3>
          <p class="feature__body">
            Casual Docs and Casual Sheets ship as web apps first; Casual Desktop
            wraps the same bundle. No second code path, no "desktop-only" feature
            drift — fixes and features in the web cores reach the desktop on the
            next release.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">∅</span>
          <h3 class="feature__title">Single-user only</h3>
          <p class="feature__body">
            Real-time co-edit stays in the Docker image where it earns its keep.
            The desktop binary is intentionally offline: open a file, edit it,
            save it. No server, no port, no port forwarding.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">📁</span>
          <h3 class="feature__title">Native file dialogs</h3>
          <p class="feature__body">
            Native macOS / Linux / Windows file pickers. Drag-and-drop from
            Finder / Explorer / nautilus into the window. The browser sandbox
            limitations on file access disappear in the desktop shell.
          </p>
        </article>
        <article class="feature">
          <span class="feature__icon">↑</span>
          <h3 class="feature__title">Signed in-app updates</h3>
          <p class="feature__body">
            The app checks GitHub Releases on launch and installs newer signed
            builds in place — verified against an embedded minisign key. Opt-out
            in Settings. Update signing, not OS code-signing.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" style="--product-accent: var(--desktop); --product-accent-soft: var(--desktop-soft);">
    <div class="container container--narrow">
      <div class="callout">
        <strong>v{version} is a hotfix on the first public binary.</strong> It
        opens OpenDocument Text (<code>.odt</code>), fixes pipe-separated
        (<code>.psv</code>) saving, makes dark mode follow the launcher across
        both editors, routes Print to a PDF on desktop, and more — see the
        changelog. Auto-update installs it in place over v0.0.2.
      </div>
      <div class="row" style="margin-top: 22px;">
        <a class="btn btn--ghost" href={releasesUrl} rel="noopener" target="_blank">All releases</a>
        <a class="btn btn--ghost" href="/changelog/">Changelog</a>
      </div>
    </div>
  </section>
</Base>
