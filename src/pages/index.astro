---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';

const title = 'Casual Office — open-source .xlsx and .docx in your browser';
const description =
  'Casual Office is a real-time, file-centric, open-source office suite. Casual Sheets (web .xlsx) and Casual Docs (web .docx) round-trip native Office files, sync via Yjs CRDT, and run as a single self-hostable container. MIT + Apache-2.0. Try the live demos.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://casualoffice.org/#person',
      name: 'Sachin Sarwa',
      url: 'https://casualoffice.org/',
      email: 'schnsrw@gmail.com',
      jobTitle: 'Software Engineer',
      sameAs: ['https://github.com/schnsrw', 'https://hub.docker.com/u/casualoffice'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://casualoffice.org/#website',
      url: 'https://casualoffice.org/',
      name: 'Casual Office',
      alternateName: 'casualoffice.org',
      description:
        'Open-source, real-time, file-centric office suite. Self-hostable. MIT + Apache-2.0.',
      publisher: { '@id': 'https://casualoffice.org/#person' },
      inLanguage: 'en',
    },
    {
      '@type': 'ItemList',
      '@id': 'https://casualoffice.org/#projects',
      name: 'Casual Office — projects',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          item: {
            '@type': 'SoftwareApplication',
            '@id': 'https://sheet.casualoffice.org/#app',
            name: 'Casual Sheets',
            applicationCategory: 'BusinessApplication',
            applicationSubCategory: 'SpreadsheetApplication',
            operatingSystem: 'Web Browser, Docker',
            url: 'https://sheet.casualoffice.org/',
            codeRepository: 'https://github.com/CasualOffice/sheets',
            license: 'https://www.apache.org/licenses/LICENSE-2.0',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            author: { '@id': 'https://casualoffice.org/#person' },
          },
        },
        {
          '@type': 'ListItem',
          position: 2,
          item: {
            '@type': 'SoftwareApplication',
            '@id': 'https://docs.casualoffice.org/#app',
            name: 'Casual Docs',
            applicationCategory: 'BusinessApplication',
            applicationSubCategory: 'WordProcessor',
            operatingSystem: 'Web Browser, Docker',
            url: 'https://docs.casualoffice.org/',
            codeRepository: 'https://github.com/CasualOffice/docs',
            license: 'https://www.apache.org/licenses/LICENSE-2.0',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            author: { '@id': 'https://casualoffice.org/#person' },
          },
        },
        {
          '@type': 'ListItem',
          position: 3,
          item: {
            '@type': 'SoftwareApplication',
            '@id': 'https://casualoffice.org/casual-desktop/#app',
            name: 'Casual Desktop',
            applicationCategory: 'DesktopEnhancementApplication',
            operatingSystem: 'macOS, Linux, Windows',
            url: 'https://casualoffice.org/casual-desktop/',
            license: 'https://www.apache.org/licenses/LICENSE-2.0',
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            author: { '@id': 'https://casualoffice.org/#person' },
          },
        },
      ],
    },
  ],
};

// docker-compose snippet. Held as a raw string and emitted via
// set:html so Astro doesn't try to interpolate the `${VAR}` segments.
const composeYml = `<code>services:
  app:
    image: casualoffice/sheets:0.3
    ports: ['3000:3000']
    environment:
      CASUAL_STORAGE: local
      CASUAL_LOCAL_PATH: /data/workbooks
    volumes:
      - data:/data
volumes:
  data:</code>`;

// Minimal React embed example — copy-pastable, three lines that
// actually mount the editor. Same shape as docx-editor.dev for
// developers comparing the two.
const reactEmbed = `<code>import { DocxEditor } from '@casualoffice/docs';

export default function App() {
  return &lt;DocxEditor onSave={(blob) =&gt; saveAs(blob, 'doc.docx')} /&gt;;
}</code>`;

// FAQ — kept honest and short. No marketing hedge in the answers.
const faqs = [
  {
    q: 'What is Casual Office, in one sentence?',
    a: 'Two real office editors — sheets + docs — that open native Office files in the browser, sync in real time, and save back to the original byte-for-byte format. Open source. Self-hostable as one Docker container.',
  },
  {
    q: 'Is this a SaaS? Will it ever be?',
    a: 'No. The public demos at sheet.casualoffice.org and docs.casualoffice.org have no accounts, no plans, no upsell. The project is permissively licensed and free forever in the editions you can see today.',
  },
  {
    q: 'How does the .xlsx / .docx round-trip work?',
    a: 'The file is the source of truth. Open → in-memory snapshot → edit → re-serialize back to the original OOXML shape. Casual Sheets carries macros and pivot caches through byte-equal. Casual Docs scores 39/39 fixtures pristine in the per-tag fidelity audit.',
  },
  {
    q: 'Real-time co-editing — what powers it?',
    a: 'Yjs (industry-standard CRDT) in the browser, paired with Hocuspocus (Casual Sheets) or a custom ~120-line Go y-websocket gateway (Casual Docs). State lives in memory while a session is active; persistence is delegated to the host integration.',
  },
  {
    q: 'Do I need a database?',
    a: 'No. Default storage is in-memory or local filesystem. Casual Sheets also ships S3-compatible and Postgres backends, plus an optional personal mode (bcrypt + SQLite) for named per-user files — pick one with a single env var or skip them entirely.',
  },
  {
    q: 'Can I embed it in my own React or Vue app?',
    a: 'Yes for Casual Docs — it ships as npm packages (`@casualoffice/docs`, `@eigenpal/docx-editor-vue`). The Go gateway is a separate process you can run alongside any backend. Casual Sheets now publishes an SDK (`@casualoffice/sheets`) for the xlsx import path plus an iframe postMessage protocol; a full React embed wrapper is in progress.',
  },
  {
    q: 'Where does it not fit?',
    a: 'If you need server-side PDF rendering, automatic version history out of the box, enterprise SSO, or compliance certifications, this is not that. It is a focused open-source pair of editors, not a managed compliance suite.',
  },
  {
    q: 'Why does this exist?',
    a: 'A counterposition to megasuites. Each product is small enough to read end-to-end, every line is on GitHub, and the file format is owned by the user — not the vendor.',
  },
];

// FAQPage structured data — makes the Q&A block eligible for Google's
// rich-result FAQ treatment. Built from the same `faqs` array the page
// renders below, so the visible markup and the schema can't drift.
jsonLd['@graph'].push({
  '@type': 'FAQPage',
  '@id': 'https://casualoffice.org/#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---
<Base {title} {description} active="home" jsonLd={jsonLd}>
  <!-- HERO — compact text, then the live demo dominates the fold -->
  <section class="hero hero--tight">
    <div class="container hero__inner">
      <span class="eyebrow">
        <span class="eyebrow__dot" aria-hidden="true"></span>
        open source · self-host · MIT + Apache-2.0
      </span>
      <h1 class="display display--xl">
        <code class="display__code">.xlsx</code> and <code class="display__code">.docx</code>,<br/>
        in your <em>browser.</em>
      </h1>
      <p class="lede lede--tight">
        Real-time multi-peer co-editing. Saves back to the same byte-for-byte file.
        No accounts, no SaaS, no upsell — try the live demos below, or
        <code>docker run</code> it on your own server.
      </p>

      <div class="row row--centered">
        <a class="btn btn--primary btn--lg" href="https://github.com/CasualOffice" rel="noopener" target="_blank" aria-label="View on GitHub">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" style="margin-right: 7px;">
            <path fill="currentColor" d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.3 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/>
          </svg>
          Star on GitHub
        </a>
        <a class="btn btn--ghost btn--lg" href="#docker">Self-host →</a>
      </div>
    </div>
  </section>

  <!-- LIVE DEMO — the headline visual. Two tabs (Sheets / Editor),
       each loads the actual production demo in an iframe. No fakes,
       no static screenshots — visitors see the real product in five
       seconds. Lazy-loaded so the iframe doesn't block first paint. -->
  <section class="demo" aria-label="Live product demo">
    <div class="container">
      <div class="demo__head">
        <div class="demo__tabs" role="tablist" aria-label="Choose a product">
          <button
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls="demo-sheets"
            id="demo-tab-sheets"
            class="demo__tab demo__tab--active"
            data-demo="sheets"
          >
            <span class="demo__tab-dot" style="background: var(--sheets);" aria-hidden="true"></span>
            Casual Sheets
            <span class="demo__tab-pill">.xlsx</span>
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            aria-controls="demo-editor"
            id="demo-tab-editor"
            class="demo__tab"
            data-demo="editor"
          >
            <span class="demo__tab-dot" style="background: var(--editor);" aria-hidden="true"></span>
            Casual Docs
            <span class="demo__tab-pill">.docx</span>
          </button>
        </div>
        <div class="demo__actions">
          <a class="demo__pop" href="https://sheet.casualoffice.org/" rel="noopener" target="_blank" data-pop-for="sheets">
            Open Sheets full-screen ↗
          </a>
          <a class="demo__pop demo__pop--hidden" href="https://docs.casualoffice.org/" rel="noopener" target="_blank" data-pop-for="editor">
            Open Editor full-screen ↗
          </a>
        </div>
      </div>

      <!-- Faux browser chrome for a polished, designed-on-purpose feel -->
      <div class="frame" style="--frame-accent: var(--sheets);" data-frame>
        <div class="frame__chrome">
          <span class="frame__btn" style="background: #ff5f57"></span>
          <span class="frame__btn" style="background: #febc2e"></span>
          <span class="frame__btn" style="background: #28c840"></span>
          <span class="frame__addr" data-addr="sheets">sheet.casualoffice.org</span>
          <span class="frame__addr frame__addr--hidden" data-addr="editor">docs.casualoffice.org</span>
        </div>
        <div
          id="demo-sheets"
          role="tabpanel"
          aria-labelledby="demo-tab-sheets"
          class="frame__panel"
        >
          <iframe
            title="Casual Sheets live demo"
            src="https://sheet.casualoffice.org/?embed=1"
            loading="lazy"
            allow="clipboard-read; clipboard-write"
          ></iframe>
        </div>
        <div
          id="demo-editor"
          role="tabpanel"
          aria-labelledby="demo-tab-editor"
          class="frame__panel frame__panel--hidden"
        >
          <iframe
            title="Casual Docs live demo"
            src="https://docs.casualoffice.org/?embed=1"
            loading="lazy"
            allow="clipboard-read; clipboard-write"
          ></iframe>
        </div>
      </div>
      <p class="demo__hint">
        Real production demos, not screenshots. Open a real file, edit it, save it back —
        nothing leaves your browser unless you click Share.
      </p>
    </div>
  </section>

  <!-- STATS BAR — concrete numbers, monospace. Same content as before
       but the live demo above means the visitor already has a reason
       to care. -->
  <section class="section section--stats">
    <div class="container">
      <div class="statline">
        <div class="stat">
          <span class="stat__label">CASUAL DOCS</span>
          <span class="stat__value">39/39</span>
          <span class="stat__hint">.docx fixtures · 100% round-trip</span>
        </div>
        <div class="stat">
          <span class="stat__label">CASUAL SHEETS</span>
          <span class="stat__value">v0.3.3</span>
          <span class="stat__hint">production-grade · WOPI host</span>
        </div>
        <div class="stat">
          <span class="stat__label">CO-EDIT</span>
          <span class="stat__value">live</span>
          <span class="stat__hint">verified end-to-end · Yjs CRDT</span>
        </div>
        <div class="stat">
          <span class="stat__label">LICENSE</span>
          <span class="stat__value">MIT + Apache</span>
          <span class="stat__hint">no AGPL, no copyleft surprises</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS — three cards, each links to the product page -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">three editors, one suite</span>
          <h2 class="title">A spreadsheet, a document editor,<br/>and a slide deck. Every line on GitHub.</h2>
        </div>
        <span class="section__hint">/products</span>
      </div>
      <div class="products">
        <ProductCard
          slug="sheets"
          name="Casual Sheets"
          role="EXCEL-FLAVORED WEB SPREADSHEET"
          body="Open .xlsx, .ods, .csv, .tsv. Real-time co-editing, pivot tables with drill-down, 8 chart types with trendlines, sparklines, version history, and .xlsm macro passthrough that round-trips byte-equal."
          features={[
            '.xlsx · .ods · .csv · .tsv round-trip',
            'Pivot tables · 8 chart types · sparklines',
            'Real-time via Yjs + Hocuspocus',
            'Self-host: memory · local · S3 · Postgres',
          ]}
          status="v0.3.3 · 398 e2e"
          href="/casual-sheets/"
          accent="var(--sheets)"
          accentSoft="var(--sheets-soft)"
        />
        <ProductCard
          slug="editor"
          name="Casual Docs"
          role="WORD-FLAVORED .DOCX EDITOR"
          body="Open .docx in the browser with WYSIWYG fidelity. Fork of eigenpal/docx-editor on top of ProseMirror with an OOXML-preserving model. The stateless Go gateway speaks the y-websocket protocol in roughly 120 lines."
          features={[
            '.docx round-trip · 39/39 fixtures pristine',
            'ProseMirror + OOXML model · page color · table fidelity',
            'Yjs + Go y-websocket gateway',
            'Co-edit verified end-to-end (smoke + tests)',
          ]}
          status="public preview · npm SDK v1.1.7"
          href="/casual-docs/"
          accent="var(--editor)"
          accentSoft="var(--editor-soft)"
        />
        <ProductCard
          slug="slides"
          name="Casual Slides"
          role="POWERPOINT-FLAVORED WEB SLIDES"
          body="Open .pptx in the browser with deep OOXML fidelity — 68 of 87 fidelity probes passing after wave 7o. Office-style ribbon, slide-panel thumbnails, layout templates, theme + background pickers, Slide Show mode. Co-edit is a Phase-2 spike today; Yjs migration is the v0.1.0 blocker."
          features={[
            '.pptx round-trip · 68 / 87 fidelity ✓',
            'Office ribbon · 6 layouts · themes · backgrounds',
            'Tables · charts · text outline · arrowheads · effects',
            'Fork-and-patch on Univer Slides OSS',
          ]}
          status="v0.0.0 · pre-tag · active"
          href="/casual-slides/"
          accent="var(--slides)"
          accentSoft="var(--slides-soft)"
        />
        <ProductCard
          slug="desktop"
          name="Casual Desktop"
          role="TAURI BINARIES · PAUSED"
          body="A native binary for macOS, Linux, and Windows that would reuse the web cores verbatim. Paused until both web editors reach feature parity; the work is queued, not abandoned."
          features={[
            'Tauri shell · reuses the web cores',
            'macOS · Linux · Windows',
            'Single-user · offline',
            'Resumes after web v1',
          ]}
          status="paused · queued"
          href="/casual-desktop/"
          accent="var(--desktop)"
          accentSoft="var(--desktop-soft)"
        />
      </div>
    </div>
  </section>

  <!-- WHY — 6 concrete differentiators with proper SVG icons -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">why bother</span>
          <h2 class="title">Six reasons to take this seriously.</h2>
        </div>
        <span class="section__hint">/why</span>
      </div>
      <div class="why">
        <article class="why__card">
          <svg class="why__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm-1 7V3.5L18.5 9H13Z"/>
          </svg>
          <h3 class="why__title">The file is the source of truth</h3>
          <p class="why__body">
            Open <code>.xlsx</code> or <code>.docx</code>, edit, save back to the
            same bytes. The audit counts every OOXML tag round-trip;
            Casual Docs is at <strong>100% on 39 fixtures</strong>.
          </p>
        </article>
        <article class="why__card">
          <svg class="why__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path fill="currentColor" d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4Z"/>
          </svg>
          <h3 class="why__title">Real-time, actually verified</h3>
          <p class="why__body">
            Yjs CRDT in the browser, a <code>~120 LOC</code> Go gateway on the
            server. A 5-second smoke proves multi-peer text, awareness, and live
            rename — every push runs it.
          </p>
        </article>
        <article class="why__card">
          <svg class="why__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path fill="currentColor" d="M21 2H3a1 1 0 0 0-1 1v18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1ZM8 18H6V8h2Zm5 0h-2V8h2Zm5 0h-2V8h2Z"/>
          </svg>
          <h3 class="why__title">Stateless backend</h3>
          <p class="why__body">
            No database, no on-disk update log in the real-time path. Session
            state lives in memory while peers are connected, then drains to
            the host integration on the last disconnect.
          </p>
        </article>
        <article class="why__card">
          <svg class="why__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path fill="currentColor" d="M12 2 4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6Zm0 10H6V7.3l6-3 6 3V12Z"/>
          </svg>
          <h3 class="why__title">Permissive, forever</h3>
          <p class="why__body">
            MIT on the editor packages, Apache-2.0 on the backend. No
            copyleft, no AGPL trapdoor, no "open core" features hidden behind
            a paid tier.
          </p>
        </article>
        <article class="why__card">
          <svg class="why__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path fill="currentColor" d="M3 4h18v3H3Zm0 13h18v3H3Zm0-6.5h18v3H3Z"/>
          </svg>
          <h3 class="why__title">One container, one port</h3>
          <p class="why__body">
            Multi-arch images (amd64 + arm64) on Docker Hub. OCI labels, SBOM
            and provenance attestations. <code>docker run</code> and you're
            running both the editor and the WS gateway.
          </p>
        </article>
        <article class="why__card">
          <svg class="why__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path fill="currentColor" d="m18.4 14.4 4.6 4.6L21 21l-4.6-4.6a8 8 0 1 1 2-2ZM10 16a6 6 0 1 0-6-6 6 6 0 0 0 6 6Z"/>
          </svg>
          <h3 class="why__title">Built in the open</h3>
          <p class="why__body">
            Every commit, every fixture, every failing-then-passing test
            visible on GitHub. The roadmap is a doc, not a slide deck. Pick
            an issue, open a PR.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- EMBED — show how trivial it is to drop Casual Docs into a
       React or Vue app. Targets developers comparing to docx-editor.dev. -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">embed</span>
          <h2 class="title">Drop it into your own app.</h2>
        </div>
        <span class="section__hint">npm</span>
      </div>
      <div class="embed">
        <div class="embed__col">
          <div class="embed__label">Install</div>
          <pre class="code-block code-block--inline"><code>npm i @casualoffice/docs</code></pre>
          <div class="embed__label embed__label--tight">Use</div>
          <pre class="code-block" set:html={reactEmbed}></pre>
        </div>
        <div class="embed__col">
          <div class="embed__label">Works with</div>
          <div class="frameworks">
            <a class="fw" href="https://github.com/CasualOffice/docs#vite" rel="noopener" target="_blank">
              <span class="fw__name">Vite</span>
            </a>
            <a class="fw" href="https://github.com/CasualOffice/docs#nextjs" rel="noopener" target="_blank">
              <span class="fw__name">Next.js</span>
            </a>
            <a class="fw" href="https://github.com/CasualOffice/docs#astro" rel="noopener" target="_blank">
              <span class="fw__name">Astro</span>
            </a>
            <a class="fw" href="https://github.com/CasualOffice/docs#remix" rel="noopener" target="_blank">
              <span class="fw__name">Remix</span>
            </a>
            <a class="fw" href="https://github.com/CasualOffice/docs#vue" rel="noopener" target="_blank">
              <span class="fw__name">Vue</span>
            </a>
            <a class="fw" href="https://github.com/CasualOffice/docs#nuxt" rel="noopener" target="_blank">
              <span class="fw__name">Nuxt</span>
            </a>
          </div>
          <p class="embed__note">
            The editor packages ship as ESM + UMD. The Go gateway is a
            separate process — run it alongside any backend that speaks
            HTTP. Casual Sheets now ships an SDK (`@casualoffice/sheets`) for xlsx
            import plus an iframe protocol; a React wrapper is in progress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SELF-HOST QUICKSTART -->
  <section class="section" id="docker">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">self-host</span>
          <h2 class="title">From zero to a running suite in one command.</h2>
        </div>
        <span class="section__hint">docker</span>
      </div>
      <pre class="code-block" set:html={composeYml}></pre>
      <div class="row" style="margin-top: 20px;">
        <a class="btn btn--ghost" href="/docs/sheets/self-hosting/">Self-hosting guide →</a>
        <a class="btn btn--ghost" href="/docs/sheets/customization-auth/">Optional JWT auth</a>
        <a class="btn btn--ghost" href="/docs/">All docs</a>
      </div>
    </div>
  </section>

  <!-- COMMUNITY — three concrete ways to participate -->
  <section class="section section--community">
    <div class="container">
      <div class="section__head">
        <div>
          <span class="eyebrow">community-first</span>
          <h2 class="title">Help shape v1.</h2>
        </div>
        <span class="section__hint">/contribute</span>
      </div>
      <div class="community">
        <div class="community__card">
