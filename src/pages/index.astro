<!-- Tab switcher for the live demo. Tiny vanilla JS — no React, no
     framework needed for two buttons. Flips ARIA attrs + show/hide
     classes. Iframes stay mounted so switching back doesn't re-load. -->
<script is:inline>
  (function () {
    const tabs = document.querySelectorAll('[data-demo]');
    const panels = {
      sheets: document.getElementById('demo-sheets'),
      editor: document.getElementById('demo-editor'),
    };
    const frame = document.querySelector('[data-frame]');
    const addrs = document.querySelectorAll('[data-addr]');
    const pops = document.querySelectorAll('[data-pop-for]');
    const FRAME_ACCENTS = {
      sheets: 'var(--sheets)',
      editor: 'var(--editor)',
    };
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.dataset.demo;
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('demo__tab--active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        Object.entries(panels).forEach(([k, panel]) => {
          if (!panel) return;
          panel.classList.toggle('frame__panel--hidden', k !== key);
        });
        if (frame) frame.style.setProperty('--frame-accent', FRAME_ACCENTS[key]);
        addrs.forEach((a) => {
          a.classList.toggle('frame__addr--hidden', a.dataset.addr !== key);
        });
        pops.forEach((p) => {
          p.classList.toggle('demo__pop--hidden', p.dataset.popFor !== key);
        });
      });
    });
  })();
</script>

