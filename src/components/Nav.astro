---
/**
 * Top navigation. Sticky, blurred backdrop. Mobile-first:
 *
 *  - ≥ 880px  → full horizontal link row.
 *  - < 880px  → brand + hamburger; links collapse into a full-width
 *               drop panel toggled by the button. The panel is keyboard
 *               reachable, closes on Escape / outside-click / link-tap,
 *               and locks body scroll while open.
 *
 * `active` highlights the matching link. The product formerly called
 * "Casual Editor" is now "Casual Docs" (route stays /casual-docs/); the
 * long-form documentation section is labelled "Guides" so the two don't
 * collide in the bar.
 *
 * The right-most "Star on GitHub" affordance is the primary CTA on a
 * community-first project — a pill, not a salesy button.
 */
type ActiveLink = 'home' | 'sheets' | 'editor' | 'slides' | 'desktop' | 'pdf' | 'docs' | 'notes' | 'changelog' | 'about';
const { active = 'home' } = Astro.props as { active?: ActiveLink };

const links: { slug: ActiveLink; label: string; href: string }[] = [
  { slug: 'sheets', label: 'Sheets', href: '/casual-sheets/' },
  { slug: 'editor', label: 'Docs', href: '/casual-docs/' },
  { slug: 'slides', label: 'Slides', href: '/casual-slides/' },
  { slug: 'desktop', label: 'Desktop', href: '/casual-desktop/' },
  { slug: 'pdf', label: 'PDF', href: '/casual-pdf/' },
  { slug: 'docs', label: 'Guides', href: '/docs/' },
  { slug: 'notes', label: 'Notes', href: '/notes/' },
  { slug: 'changelog', label: 'Changelog', href: '/changelog/' },
];
---

<nav class="nav" aria-label="Primary" data-nav>
  <a class="nav__brand" href="/" aria-label="Casual Office home">
    <span class="nav__mark" aria-hidden="true"></span>
    Casual Office
  </a>

  <button
    type="button"
    class="nav__toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-menu"
    data-nav-toggle
  >
    <span class="nav__toggle-bars" aria-hidden="true"><span></span><span></span><span></span></span>
  </button>

  <div class="nav__links" id="nav-menu" data-nav-menu>
    {links.map((l) => (
      <a
        class={l.slug === active ? 'nav__link nav__link--active' : 'nav__link'}
        href={l.href}
        aria-current={l.slug === active ? 'page' : undefined}
      >{l.label}</a>
    ))}
    <a
      class="nav__star"
      href="https://github.com/CasualOffice"
      rel="noopener"
      target="_blank"
      aria-label="View on GitHub"
    >
      <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
        <path
          fill="currentColor"
          d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.3 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
        />
      </svg>
      <span class="nav__star-label">Star on GitHub</span>
    </a>
  </div>

  <span class="nav__scrim" data-nav-scrim aria-hidden="true"></span>
</nav>

<script is:inline>
  (function () {
    const nav = document.querySelector('[data-nav]');
    if (!nav) return;
    const toggle = nav.querySelector('[data-nav-toggle]');
    const menu = nav.querySelector('[data-nav-menu]');
    const scrim = nav.querySelector('[data-nav-scrim]');
    const mq = window.matchMedia('(max-width: 879px)');

    function setOpen(open) {
      nav.classList.toggle('nav--open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      // Only trap scroll on the mobile breakpoint.
      document.body.style.overflow = open && mq.matches ? 'hidden' : '';
    }

    toggle.addEventListener('click', () => setOpen(!nav.classList.contains('nav--open')));
    scrim && scrim.addEventListener('click', () => setOpen(false));
    menu.addEventListener('click', (e) => {
      if (e.target.closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
    // Reset state if the viewport grows past the mobile breakpoint.
    mq.addEventListener('change', () => setOpen(false));
  })();
</script>

<style>
  /* Hamburger button — hidden on desktop, shown under 880px. */
  .nav__toggle {
    display: none;
    appearance: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    margin: -4px -6px -4px 0;
    padding: 0;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 10px;
    color: var(--text);
    cursor: pointer;
    transition: background-color 120ms ease, border-color 120ms ease;
  }
  .nav__toggle:hover { background: var(--surface-2); }
  .nav__toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .nav__toggle-bars,
  .nav__toggle-bars span {
    display: block;
    box-sizing: border-box;
  }
  .nav__toggle-bars {
    position: relative;
    width: 20px;
    height: 14px;
  }
  .nav__toggle-bars span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transition: transform 200ms ease, opacity 160ms ease, top 200ms ease;
  }
  .nav__toggle-bars span:nth-child(1) { top: 0; }
  .nav__toggle-bars span:nth-child(2) { top: 6px; }
  .nav__toggle-bars span:nth-child(3) { top: 12px; }
  .nav--open .nav__toggle-bars span:nth-child(1) { top: 6px; transform: rotate(45deg); }
  .nav--open .nav__toggle-bars span:nth-child(2) { opacity: 0; }
  .nav--open .nav__toggle-bars span:nth-child(3) { top: 6px; transform: rotate(-45deg); }

  .nav__star {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    margin-left: 8px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    transition:
      border-color 120ms ease,
      background-color 120ms ease,
      color 120ms ease;
    background: var(--surface);
  }
  .nav__star:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .nav__scrim { display: none; }

  /* ── Mobile: collapse links into a drop panel ───────────────────── */
  @media (max-width: 879px) {
    .nav__toggle { display: inline-flex; }

    .nav__links {
      position: absolute;
      top: calc(100% + 1px);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
      padding: 10px 16px calc(14px + env(safe-area-inset-bottom));
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
      transform: translateY(-8px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 180ms ease, transform 180ms ease, visibility 0s linear 180ms;
    }
    .nav--open .nav__links {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: opacity 180ms ease, transform 180ms ease, visibility 0s;
    }
    .nav__link {
      padding: 12px 12px;
      font-size: 16px;
      border-radius: 10px;
    }
    .nav__star {
      margin: 8px 0 0;
      justify-content: center;
      padding: 12px;
      font-size: 14px;
    }
    .nav__star-label { display: inline; }

    .nav--open .nav__scrim {
      display: block;
      position: fixed;
      inset: 0;
      top: 0;
      z-index: -1;
      background: rgba(12, 10, 9, 0.32);
      -webkit-backdrop-filter: blur(1px);
      backdrop-filter: blur(1px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__links,
    .nav__toggle-bars span { transition: none; }
  }
</style>
