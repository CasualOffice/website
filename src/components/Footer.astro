---
const year = new Date().getFullYear();

// Structured footer — a brand column with the one-line pitch + open-source
// signals, then three navigation columns. Reads as a maintained project,
// not a personal page.
const columns: { title: string; links: { label: string; href: string; external?: boolean }[] }[] = [
  {
    title: 'Products',
    links: [
      { label: 'Casual Sheets', href: '/casual-sheets/' },
      { label: 'Casual Docs', href: '/casual-docs/' },
      { label: 'Casual Slides', href: '/casual-slides/' },
      { label: 'Casual Desktop', href: '/casual-desktop/' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Guides', href: '/docs/' },
      { label: 'Changelog', href: '/changelog/' },
      { label: 'Engineering notes', href: '/notes/' },
      { label: 'Comparisons', href: '/vs/' },
    ],
  },
  {
    title: 'Project',
    links: [
      { label: 'About', href: '/about/' },
      { label: 'Contributing', href: '/contributing/' },
      { label: 'License', href: '/license/' },
      { label: 'GitHub', href: 'https://github.com/CasualOffice', external: true },
    ],
  },
];
---
<footer class="foot">
  <div class="container foot__top">
    <div class="foot__brand">
      <a class="foot__logo" href="/" aria-label="Casual Office home">
        <span class="nav__mark" aria-hidden="true"></span>
        Casual Office
      </a>
      <p class="foot__tag">
        An open-source, self-hosted office suite — real <code>.xlsx</code>,
        <code>.docx</code>, and <code>.pptx</code> in the browser, with real-time
        co-editing. A Google Docs &amp; Microsoft Office alternative you run yourself.
      </p>
      <ul class="foot__signals" aria-label="Project facts">
        <li>Apache-2.0 + MIT</li>
        <li>Self-hostable</li>
        <li>Multi-arch Docker</li>
        <li>Built in the open</li>
      </ul>
      <a class="foot__gh" href="https://github.com/CasualOffice" rel="noopener" target="_blank">
        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
          <path fill="currentColor" d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.3 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/>
        </svg>
        Star the org on GitHub →
      </a>
    </div>

    <nav class="foot__nav" aria-label="Footer">
      {columns.map((col) => (
        <div class="foot__col-block">
          <h2 class="foot__col-title">{col.title}</h2>
          <ul class="foot__col-list">
            {col.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  {...(l.external ? { rel: 'noopener', target: '_blank' } : {})}
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="container foot__bottom">
    <span>© {year} Casual Office · built by <a href="https://github.com/schnsrw" rel="noopener" target="_blank">Sachin Sarwa</a></span>
    <span class="foot__bottom-meta">Apache-2.0 / MIT · every line on GitHub</span>
  </div>
</footer>
